    {
      "name": "Admin",
      "description": "Internal feedback loops.",
      "item": [
        {
          "name": "Log admin correction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticket_id\": \"{{ticketId}}\",\n  \"original_text\": \"My laptop won't connect to the VPN\",\n  \"ocr_text\": \"\",\n  \"confidence\": 0.42,\n  \"original_prediction\": {\n    \"category\": \"Software\",\n    \"subcategory\": \"Other\",\n    \"priority\": \"Medium\",\n    \"assigned_team\": \"General Support\"\n  },\n  \"corrected_prediction\": {\n    \"category\": \"Network\",\n    \"subcategory\": \"VPN\",\n    \"priority\": \"High\",\n    \"assigned_team\": \"Network Support\"\n  }\n}"
